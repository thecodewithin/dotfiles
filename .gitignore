# Keep undo directories but ignore their contents
vim/.undodir/**
!vim/.undodir/.gitkeep
nvim/.config/nvim/undodir/**
!nvim/.config/nvim/undodir/.gitkeep

# Vim NetRW history
vim/.vim/.netrwhist

# Lazy‑Nvim lock file (generated)
nvim/.config/nvim/lazy-lock.json

# Generic temporary files
*~
.#*
.DS_Store
Thumbs.db
